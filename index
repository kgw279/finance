<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FinanceFlow | Personal Analytics</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://apis.google.com/js/api.js"></script>
    <script src="https://accounts.google.com/gsi/client"></script>
    <style>
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(229, 231, 235, 0.5);
        }
        .gradient-bg {
            background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
        }
    </style>
</head>
<body class="gradient-bg min-h-screen font-sans text-gray-900">

    <div class="max-w-7xl mx-auto px-4 py-8">
        <!-- Header -->
        <header class="flex flex-col md:flex-row justify-between items-center mb-10 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-indigo-900">FinanceFlow</h1>
                <p class="text-gray-600">Real-time Google Sheets Insights</p>
            </div>
            
            <div class="flex gap-3">
                <button id="auth_button" onclick="handleAuthClick()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-medium transition shadow-md">
                    Connect Google Account
                </button>
                <button id="signout_button" onclick="handleSignoutClick()" class="hidden bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 px-6 py-2 rounded-lg font-medium transition">
                    Sign Out
                </button>
            </div>
        </header>

        <!-- Configuration Modal -->
        <div id="setup_section" class="glass-card p-6 rounded-2xl mb-8 shadow-sm border-l-4 border-indigo-500">
            <h2 class="text-lg font-semibold mb-2">1. Locate Your Spreadsheet Data</h2>
            <p class="text-sm text-gray-600 mb-4 font-mono bg-indigo-50 p-2 rounded">
                URL: https://docs.google.com/spreadsheets/d/<span class="text-indigo-600 font-bold">SPREADSHEET_ID</span>/edit
            </p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-xs font-bold text-gray-500 mb-1">SPREADSHEET ID</label>
                    <input type="text" id="spreadsheet_id" placeholder="Paste the long ID from your URL" class="w-full border p-2 rounded-md focus:ring-2 focus:ring-indigo-300 outline-none">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-500 mb-1">DATA RANGE (SheetName!A:E)</label>
                    <input type="text" id="range_input" placeholder="e.g. Transactions!A1:E100" class="w-full border p-2 rounded-md focus:ring-2 focus:ring-indigo-300 outline-none">
                </div>
                <div class="flex items-end">
                    <button onclick="fetchData()" class="w-full bg-indigo-600 text-white font-semibold py-2 px-4 rounded-md hover:bg-indigo-700 transition shadow-sm">
                        Sync Live Data
                    </button>
                </div>
            </div>
        </div>

        <!-- Dashboard Grid -->
        <main id="dashboard" class="hidden">
            <!-- Stats Row -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="glass-card p-6 rounded-2xl shadow-sm">
                    <p class="text-sm text-gray-500 uppercase font-bold tracking-wider">Total Income</p>
                    <h3 id="total_income" class="text-3xl font-bold text-green-600">$0.00</h3>
                </div>
                <div class="glass-card p-6 rounded-2xl shadow-sm">
                    <p class="text-sm text-gray-500 uppercase font-bold tracking-wider">Total Expenses</p>
                    <h3 id="total_expenses" class="text-3xl font-bold text-red-600">$0.00</h3>
                </div>
                <div class="glass-card p-6 rounded-2xl shadow-sm">
                    <p class="text-sm text-gray-500 uppercase font-bold tracking-wider">Net Savings</p>
                    <h3 id="net_savings" class="text-3xl font-bold text-indigo-600">$0.00</h3>
                </div>
            </div>

            <!-- Charts Row -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
                <div class="glass-card p-6 rounded-2xl shadow-sm min-h-[400px]">
                    <h4 class="text-lg font-semibold mb-4">Spending by Category</h4>
                    <div class="relative h-64">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>
                <div class="glass-card p-6 rounded-2xl shadow-sm min-h-[400px]">
                    <h4 class="text-lg font-semibold mb-4">Transaction Volume</h4>
                    <div class="relative h-64">
                        <canvas id="trendChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Data Table -->
            <div class="glass-card rounded-2xl shadow-sm overflow-hidden">
                <div class="p-6 border-b border-gray-100 flex justify-between items-center">
                    <h4 class="text-lg font-semibold">Raw Spreadsheet View</h4>
                    <span id="row_count" class="text-xs bg-gray-100 px-2 py-1 rounded text-gray-500">0 rows</span>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-gray-50">
                            <tr id="table_headers"></tr>
                        </thead>
                        <tbody id="table_body" class="divide-y divide-gray-100 text-sm"></tbody>
                    </table>
                </div>
            </div>
        </main>
        
        <div id="empty_state" class="text-center py-20">
            <div class="bg-white w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 shadow-sm">
                <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <h2 class="text-xl font-medium text-gray-600">Waiting for Authentication</h2>
            <p class="text-gray-400">Please click 'Connect' above to grant access to your Google Sheets.</p>
        </div>
    </div>

    <script>
        /* CREDENTIALS SETUP:
           1. Go to https://console.cloud.google.com/
           2. APIs & Services > Credentials
           3. Create API KEY and OAuth Client ID (Web Application)
        */
        const CLIENT_ID = '323221869326-en1936d6cg90qcmmm1gp2rpoo7tu50ak.apps.googleusercontent.com';
        const API_KEY = 'AIzaSyDte0cZEz2KjHVKFnKn6qQfLAhgvYFoqdg';
        const SCOPES = 'https://www.googleapis.com/auth/spreadsheets.readonly';

        let tokenClient;
        let gapiInited = false;
        let gisInited = false;
        let categoryChart, trendChart;

        function gapiLoaded() {
            gapi.load('client', intializeGapiClient);
        }

        async function intializeGapiClient() {
            await gapi.client.init({
                apiKey: API_KEY,
                discoveryDocs: ['https://sheets.googleapis.com/$discovery/rest?version=v4'],
            });
            gapiInited = true;
            checkReady();
        }

        function gisLoaded() {
            tokenClient = google.accounts.oauth2.initTokenClient({
                client_id: CLIENT_ID,
                scope: SCOPES,
                callback: '', 
            });
            gisInited = true;
            checkReady();
        }

        function checkReady() {
            if (gapiInited && gisInited) {
                document.getElementById('auth_button').style.display = 'block';
            }
        }

        function handleAuthClick() {
            tokenClient.callback = async (resp) => {
                if (resp.error !== undefined) throw (resp);
                document.getElementById('auth_button').classList.add('hidden');
                document.getElementById('signout_button').classList.remove('hidden');
                document.getElementById('dashboard').classList.remove('hidden');
                document.getElementById('empty_state').classList.add('hidden');
                showToast("Connected to Google!");
            };

            if (gapi.client.getToken() === null) {
                tokenClient.requestAccessToken({prompt: 'consent'});
            } else {
                tokenClient.requestAccessToken({prompt: ''});
            }
        }

        function handleSignoutClick() {
            const token = gapi.client.getToken();
            if (token !== null) {
                google.accounts.oauth2.revoke(token.access_token);
                gapi.client.setToken('');
                location.reload(); // Simplest way to reset state
            }
        }

        async function fetchData() {
            const spreadsheetId = document.getElementById('spreadsheet_id').value.trim();
            const range = document.getElementById('range_input').value.trim() || 'Sheet1!A1:E100';

            if (!spreadsheetId) {
                showToast("❌ Error: Missing Spreadsheet ID");
                return;
            }

            if (gapi.client.getToken() === null) {
                showToast("⚠️ Please connect your Google account first.");
                return;
            }

            try {
                const response = await gapi.client.sheets.spreadsheets.values.get({
                    spreadsheetId: spreadsheetId,
                    range: range,
                });
                const rangeData = response.result.values;
                if (!rangeData || rangeData.length === 0) {
                    showToast("No data found in that range.");
                    return;
                }
                processFinancialData(rangeData);
                showToast("✅ Data synced successfully!");
            } catch (err) {
                console.error(err);
                showToast("Error: Check ID or Permissions.");
            }
        }

        function processFinancialData(rows) {
            const headers = rows[0];
            const data = rows.slice(1);
            document.getElementById('row_count').innerText = `${data.length} transactions`;

            // Populate Table
            const headerRow = document.getElementById('table_headers');
            headerRow.innerHTML = headers.map(h => `<th class="px-6 py-3 font-bold text-gray-600 uppercase text-xs">${h}</th>`).join('');

            const body = document.getElementById('table_body');
            body.innerHTML = data.map(row => `
                <tr class="hover:bg-indigo-50/30 transition">
                    ${row.map(cell => `<td class="px-6 py-3 border-t border-gray-100">${cell}</td>`).join('')}
                </tr>
            `).join('');

            /* DATA MAPPING LOGIC
               Assumes standard columns: Date, Category, Description, Amount, Type
            */
            let income = 0;
            let expenses = 0;
            const categories = {};

            data.forEach(row => {
                // Sanitize amount (remove $ and commas)
                const rawAmount = row[3] ? row[3].toString().replace(/[^0-9.-]+/g,"") : "0";
                const amount = parseFloat(rawAmount) || 0;
                const type = row[4] ? row[4].toLowerCase().trim() : 'expense';
                const cat = row[1] || 'Uncategorized';

                if (type === 'income') {
                    income += amount;
                } else {
                    expenses += amount;
                    categories[cat] = (categories[cat] || 0) + amount;
                }
            });

            document.getElementById('total_income').innerText = `$${income.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('total_expenses').innerText = `$${expenses.toLocaleString(undefined, {minimumFractionDigits: 2})}`;
            document.getElementById('net_savings').innerText = `$${(income - expenses).toLocaleString(undefined, {minimumFractionDigits: 2})}`;

            renderCharts(categories, data);
        }

        function renderCharts(categories, allData) {
            if (categoryChart) categoryChart.destroy();
            const ctx1 = document.getElementById('categoryChart').getContext('2d');
            categoryChart = new Chart(ctx1, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(categories),
                    datasets: [{
                        data: Object.values(categories),
                        backgroundColor: ['#6366f1', '#818cf8', '#a5b4fc', '#c7d2fe', '#e0e7ff', '#4338ca'],
                        borderWidth: 2,
                        hoverOffset: 10
                    }]
                },
                options: { 
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom' } }
                }
            });

            if (trendChart) trendChart.destroy();
            const ctx2 = document.getElementById('trendChart').getContext('2d');
            trendChart = new Chart(ctx2, {
                type: 'bar',
                data: {
                    labels: allData.slice(-10).map(r => r[0] || 'N/A'), // Last 10 dates
                    datasets: [{
                        label: 'Transaction Amount',
                        data: allData.slice(-10).map(r => parseFloat(r[3].toString().replace(/[^0-9.-]+/g,"")) || 0),
                        backgroundColor: '#6366f1',
                        borderRadius: 5
                    }]
                },
                options: { 
                    maintainAspectRatio: false,
                    scales: { y: { beginAtZero: true } }
                }
            });
        }

        function showToast(msg) {
            const toast = document.createElement('div');
            toast.className = "fixed bottom-5 right-5 bg-indigo-900 text-white px-6 py-3 rounded-lg shadow-2xl z-50 transition-all duration-300 transform translate-y-0";
            toast.innerText = msg;
            document.body.appendChild(toast);
            setTimeout(() => { 
                toast.classList.add('opacity-0', 'translate-y-2');
                setTimeout(() => toast.remove(), 300); 
            }, 3500);
        }

        window.onload = () => {
            gapiLoaded();
            gisLoaded();
        };
    </script>
</body>
</html>
